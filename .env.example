# AI Block System - Environment Variables
# Copy this to .env and fill in your values

# Server Configuration
PORT=8000
HOST=0.0.0.0
DATA_DIR=/app/data

# Vector Search (ChromaDB)
CHROMA_PERSIST_DIR=/app/data/chroma_db
VECTOR_COLLECTION=default
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI API (for Chat, Image, Voice, Embeddings)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API (for Chat with Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Translation
DEEPL_API_KEY=your-deepl-key

# Google Drive
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# OneDrive
ONEDRIVE_ACCESS_TOKEN=your-onedrive-token

# Local Drive
LOCAL_DRIVE_PATH=/app/data

# Android Drive (for Android deployments)
ANDROID_ROOT=/sdcard
ANDROID_APP_DATA=/data/data/com.cerebrum.app/files
ANDROID_SHARED_STORAGE=/sdcard
