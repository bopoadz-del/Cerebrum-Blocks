# Cerebrum Blocks Environment Variables

# Server
PORT=8000
HOST=0.0.0.0
DATA_DIR=./data

# API Keys (set at least one for production)
CEREBRUM_MASTER_KEY=your-master-api-key-here
# CEREBRUM_API_KEY_user1=sk-user1-key-here

# AI Provider Keys (optional - only needed for real AI features)
# DeepSeek = cheapest ($0.14/M tokens)
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Groq = fastest
GROQ_API_KEY=gsk-your-groq-key
# OpenAI = most capable
OPENAI_API_KEY=sk-your-openai-key
# Anthropic = best reasoning
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Vector Search
CHROMA_PERSIST_DIR=./data/chroma_db
VECTOR_COLLECTION=default
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search (optional)
SERPER_API_KEY=your-serper-key

# Google Drive (optional)
GOOGLE_CREDENTIALS_PATH=./data/credentials.json

# OneDrive (optional)
ONEDRIVE_ACCESS_TOKEN=your-ms-graph-token

# SDK Configuration (for local development)
CEREBRUM_BASE_URL=http://localhost:8000
